{
  "extends": "@vtex/tsconfig",
  "compilerOptions": {
    // @vtex/tsconfig usa `jsx: "react"` (o clássico, precisa de `import React`)
    // e `module: "es6"` — este projeto usa o JSX automático (sem `import
    // React`) e o webpack/babel já resolvem ESM livremente, então overridamos
    // só essas duas. `noImplicitAny: false` também é intencional: o escape
    // hatch `(window as any).vtexjs`/orderForm não tipado se propaga por
    // vários hooks (ver CLAUDE.md), then forçar `noImplicitAny` custaria mais
    // do que ajudaria aqui.
    "jsx": "preserve",
    "module": "esnext",
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "noEmitOnError": true,
    "baseUrl": ".",
    "paths": {
      "~components/*": ["src/components/*"],
      "~hooks/*": ["src/hooks/*"],
      "~utils/*": ["src/utils/*"]
    }
  },
  "exclude": ["node_modules"],
  "include": [
    "./typings/*.d.ts",
    "./**/*.tsx",
    "./**/*.ts"
  ]
}
