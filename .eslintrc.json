{
  "root": true,
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "ignorePatterns": ["node_modules", "template"]
}
