{
  "name": "create-vtex-checkout",
  "version": "1.0.0",
  "description": "CLI para criar checkouts VTEX com React",
  "bin": {
    "create-vtex-checkout": "./bin/index.js"
  },
  "files": [
    "bin",
    "template"
  ],
  "scripts": {
    "lint": "eslint \"bin/**/*.js\"",
    "lint:fix": "eslint \"bin/**/*.js\" --fix",
    "format": "prettier --write \"bin/**/*.js\"",
    "prepare": "husky"
  },
  "keywords": [
    "vtex",
    "checkout",
    "react",
    "cli",
    "boilerplate"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "fs-extra": "^11.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "bin/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
